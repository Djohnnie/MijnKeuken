@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudTextField T="string" @bind-Value="Note" Label="Bezorgnotitie" Variant="Variant.Outlined"
                      Placeholder="bijv. boodschappen bij Albert Heijn" AutoFocus="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuleren</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Opslaan</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public string Note { get; set; } = string.Empty;

    private void Cancel() => MudDialog.Cancel();
    private void Submit() => MudDialog.Close(DialogResult.Ok(Note));
}
