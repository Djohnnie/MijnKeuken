@page "/account/profile"
@using MijnKeuken.Application.Users.DTOs
@using MijnKeuken.Web.Auth
@using MijnKeuken.Web.Services
@inject IUserService UserService
@inject JwtAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>Profiel</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small">
    @if (_profile is null && _errorMessage is null)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Medium" Class="mt-6" />
    }
    else if (_errorMessage is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mt-6" Dense="true" Variant="Variant.Outlined">@_errorMessage</MudAlert>
    }
    else
    {
        <MudPaper Class="pa-5 mt-4" Elevation="0" Style="border:1px solid var(--mud-palette-lines-default);">
            <MudText Typo="Typo.h4" GutterBottom="true">Mijn profiel</MudText>

            <MudList T="string" Dense="true">
                <MudListItem T="string" Icon="@Icons.Material.Rounded.PersonOutline" IconSize="Size.Small">
                    <MudText Typo="Typo.body2"><strong>Gebruikersnaam:</strong> @_profile!.Username</MudText>
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Rounded.Email" IconSize="Size.Small">
                    <MudText Typo="Typo.body2"><strong>E-mail:</strong> @_profile.Email</MudText>
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Rounded.CheckCircleOutline" IconSize="Size.Small">
                    <MudText Typo="Typo.body2"><strong>Status:</strong> @(_profile.IsApproved ? "Goedgekeurd" : "Wacht op goedkeuring")</MudText>
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Rounded.CalendarToday" IconSize="Size.Small">
                    <MudText Typo="Typo.body2"><strong>Geregistreerd:</strong> @_profile.CreatedAt.ToLocalTime().ToString("dd-MM-yyyy HH:mm")</MudText>
                </MudListItem>
                <MudListItem T="string" Icon="@(_profile.PrefersDarkMode ? Icons.Material.Rounded.DarkMode : Icons.Material.Rounded.LightMode)" IconSize="Size.Small">
                    <MudText Typo="Typo.body2"><strong>Thema:</strong> @(_profile.PrefersDarkMode ? "Donker" : "Licht")</MudText>
                </MudListItem>
            </MudList>
        </MudPaper>
    }
</MudContainer>

@code {
    private UserProfileDto? _profile;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var userId = AuthStateProvider.GetCurrentUserId();
        if (userId is null)
        {
            Navigation.NavigateTo("/account/login");
            return;
        }

        var result = await UserService.GetProfileAsync();
        if (result.IsSuccess)
            _profile = result.Value;
        else
            _errorMessage = result.Error;
    }
}
