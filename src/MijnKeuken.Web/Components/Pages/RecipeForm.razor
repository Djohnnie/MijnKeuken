@page "/recipes/new"
@page "/recipes/{Id:guid}/edit"
@using Microsoft.AspNetCore.Components.Web
@using MijnKeuken.Application.Ingredients.DTOs
@using MijnKeuken.Application.Tags.DTOs
@using MijnKeuken.Domain.Entities
@using Markdig
@using MudBlazor
@using MijnKeuken.Web.Services
@inject IRecipeService RecipeService
@inject ITagService TagService
@inject IIngredientService IngredientService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ScrapedRecipeState ScrapedState

<PageTitle>@(_isEdit ? "Recept bewerken" : "Nieuw recept")</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium">
    @if (_loading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Medium" />
    }
    else if (_notFound)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">Recept niet gevonden.</MudAlert>
        <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.ArrowBack"
                   OnClick="NavigateBack" Class="mt-3">Terug naar recepten</MudButton>
    }
    else
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
            <MudIconButton Icon="@Icons.Material.Rounded.ArrowBack" Size="Size.Small"
                           OnClick="NavigateBack" />
            <MudText Typo="Typo.h4">@(_isEdit ? "Recept bewerken" : "Nieuw recept")</MudText>
        </MudStack>

        <div style="display:flex;gap:16px;width:100%;align-items:start;" class="mb-3">
            <MudTextField T="string" @bind-Value="_title" Label="Titel" Required="true"
                          RequiredError="Titel is verplicht" Variant="Variant.Outlined"
                          Immediate="true" Margin="Margin.Dense" Style="flex:1;min-width:0;" />
            <div style="width:190px;flex-shrink:0;">
                <MudNumericField T="int" @bind-Value="_servings" Label="Aantal personen" Variant="Variant.Outlined"
                                 Margin="Margin.Dense" Min="1" Max="99"
                                 ReadOnly="@_isEdit"
                                 Adornment="@(_isEdit ? Adornment.End : Adornment.None)"
                                 AdornmentIcon="@Icons.Material.Rounded.Calculate"
                                 AdornmentColor="Color.Primary" OnAdornmentClick="OpenRecalculateDialog" />
            </div>
        </div>

        <MudTextField T="string" @bind-Value="_description" Label="Omschrijving" Variant="Variant.Outlined"
                      Margin="Margin.Dense" Class="mb-3" Sizing="InputSizing.Auto" Lines="2" MaxLines="8" />

        @if (!string.IsNullOrWhiteSpace(_sourceUrl))
        {
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-3">
                <MudTextField T="string" @bind-Value="_sourceUrl" Label="Bron URL" Variant="Variant.Outlined"
                              Margin="Margin.Dense" ReadOnly="true" Style="flex:1;" />
                <MudIconButton Icon="@Icons.Material.Rounded.OpenInNew" Size="Size.Small" Color="Color.Primary"
                               Href="@_sourceUrl" Target="_blank" Title="Bronpagina openen" />
            </MudStack>
        }

        <MudText Typo="Typo.body2" Class="mb-1">Plan (Markdown)</MudText>
        <MudTabs Elevation="0" Border="true" ApplyEffectsToContainer="true" Class="mb-3" MinimumTabWidth="80px">
            <MudTabPanel Text="Bewerken" Icon="@Icons.Material.Rounded.Edit">
                <MudTextField T="string" @bind-Value="_plan" Variant="Variant.Outlined"
                              Margin="Margin.Dense" Lines="10" Immediate="true"
                              Placeholder="Schrijf je bereidingswijze in Markdown..." />
            </MudTabPanel>
            <MudTabPanel Text="Voorbeeld" Icon="@Icons.Material.Rounded.Visibility">
                <div class="markdown-preview pa-2" style="min-height:200px;border:1px solid var(--mud-palette-lines-default);border-radius:4px;">
                    @((MarkupString)RenderMarkdown(_plan))
                </div>
            </MudTabPanel>
        </MudTabs>

        <MudText Typo="Typo.body2" Class="mb-1">Tags</MudText>
        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mb-3">
            @foreach (var tag in _availableTags)
            {
                var isSelected = _selectedTagIds.Contains(tag.Id);
                <MudChip T="string" Size="Size.Small"
                         Style="@(isSelected ? $"background:{tag.Color};color:white;" : "")"
                         Variant="@(isSelected ? Variant.Filled : Variant.Outlined)"
                         OnClick="() => ToggleTag(tag.Id)">
                    @tag.Name
                </MudChip>
            }
            @if (!_availableTags.Any())
            {
                <MudText Typo="Typo.caption" Color="Color.Tertiary">Geen recept-tags beschikbaar</MudText>
            }
        </MudStack>

        <MudText Typo="Typo.body2" Class="mb-1">Ingrediënten</MudText>
        <MudDataGrid T="RecipeIngredientModel" Items="_gridItems" Dense="true" Class="mb-3 ingredient-grid"
                     Elevation="0" Bordered="true" ReadOnly="false">
            <Columns>
                <TemplateColumn T="RecipeIngredientModel" Title="" Sortable="false" Filterable="false" CellStyle="width:36px;padding:4px;">
                    <CellTemplate>
                        @if (!context.Item.IsNewRow)
                        {
                            <div style="display:flex;align-items:center;justify-content:center;height:100%;">
                                <MudIcon Icon="@(context.Item.IsManaged ? Icons.Material.Rounded.Inventory2 : Icons.Material.Rounded.TextFields)"
                                         Size="Size.Small" Color="@(context.Item.IsManaged ? Color.Primary : Color.Default)"
                                         Title="@(context.Item.IsManaged ? "Beheerd ingrediënt" : "Vrije tekst")" />
                            </div>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn T="RecipeIngredientModel" Title="Ingrediënt" Sortable="false" Filterable="false" CellStyle="min-width:220px;">
                    <CellTemplate>
                        @if (context.Item.IsNewRow)
                        {
                            <div style="position:relative;">
                                <MudTextField T="string" Value="context.Item.DisplayName" Immediate="true"
                                              ValueChanged="v => OnIngredientTextChanged(context.Item, v)"
                                              Variant="Variant.Text" Margin="Margin.Dense" DisableUnderLine="true"
                                              Placeholder="Nieuw ingrediënt..."
                                              OnKeyDown="e => OnRowKeyDown(context.Item, e)" />
                                @{ var suggestions = GetSuggestionsFor(context.Item); }
                                @if (suggestions.Any())
                                {
                                    <MudPaper Elevation="4" Style="position:absolute;z-index:10;width:100%;max-height:200px;overflow-y:auto;">
                                        <MudList T="string" Dense="true">
                                            @foreach (var s in suggestions)
                                            {
                                                <MudListItem T="string" OnClick="() => SelectSuggestionFor(context.Item, s)">
                                                    @s
                                                </MudListItem>
                                            }
                                        </MudList>
                                    </MudPaper>
                                }
                            </div>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">@context.Item.DisplayName</MudText>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn T="RecipeIngredientModel" Title="Hoeveelheid" Sortable="false" Filterable="false" CellStyle="width:110px;">
                    <CellTemplate>
                        <MudNumericField T="decimal" @bind-Value="context.Item.Amount"
                                         Variant="Variant.Text" Margin="Margin.Dense" Min="0.01m" DisableUnderLine="true"
                                         Format="G29" />
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn T="RecipeIngredientModel" Title="Eenheid" Sortable="false" Filterable="false" CellStyle="width:130px;">
                    <CellTemplate>
                        <MudSelect T="UnitType" @bind-Value="context.Item.Unit"
                                   Variant="Variant.Text" Margin="Margin.Dense" Dense="true" DisableUnderLine="true">
                            <MudSelectItem T="UnitType" Value="UnitType.Grams">Gram</MudSelectItem>
                            <MudSelectItem T="UnitType" Value="UnitType.Units">Stuks</MudSelectItem>
                            <MudSelectItem T="UnitType" Value="UnitType.Percentage">Percentage</MudSelectItem>
                        </MudSelect>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn T="RecipeIngredientModel" Title="" Sortable="false" Filterable="false" CellStyle="width:48px;padding:4px;">
                    <CellTemplate>
                        <div style="display:flex;align-items:center;justify-content:center;height:100%;">
                            @if (context.Item.IsNewRow)
                            {
                                <MudIconButton Icon="@Icons.Material.Rounded.Add" Size="Size.Small" Color="Color.Primary"
                                               OnClick="CommitNewRow" Disabled="@(string.IsNullOrWhiteSpace(context.Item.DisplayName))" />
                            }
                            else
                            {
                                <MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small" Color="Color.Error"
                                               OnClick="() => RemoveIngredient(context.Item)" />
                            }
                        </div>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>

        @if (_errorMessage is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-3" Dense="true" Variant="Variant.Outlined">@_errorMessage</MudAlert>
        }

        <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd" Class="mb-4">
            <MudButton OnClick="NavigateBack" Size="Size.Small">Annuleren</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small"
                       OnClick="Submit" Disabled="@(string.IsNullOrWhiteSpace(_title) || _saving)">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                @(_isEdit ? "Opslaan" : "Aanmaken")
            </MudButton>
        </MudStack>
    }
</MudContainer>

@code {
    private static readonly MarkdownPipeline Pipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    [Parameter] public Guid? Id { get; set; }

    private bool _isEdit;
    private bool _loading = true;
    private bool _notFound;
    private bool _saving;
    private string _title = string.Empty;
    private string _description = string.Empty;
    private string _plan = string.Empty;
    private int _servings = 2;
    private string _sourceUrl = string.Empty;
    private List<Guid> _selectedTagIds = [];
    private List<RecipeIngredientModel> _selectedIngredients = [];
    private List<TagDto> _availableTags = [];
    private List<IngredientDto> _allIngredients = [];
    private RecipeIngredientModel _newRow = CreateNewRow();
    private string? _errorMessage;

    private IEnumerable<RecipeIngredientModel> _gridItems
        => _selectedIngredients.Append(_newRow);

    protected override async Task OnInitializedAsync()
    {
        _isEdit = Id.HasValue;

        var tagsTask = TagService.GetAllAsync();
        var ingredientsTask = IngredientService.GetAllAsync();

        if (_isEdit)
        {
            var recipeTask = RecipeService.GetByIdAsync(Id!.Value);
            await Task.WhenAll(tagsTask, ingredientsTask, recipeTask);

            var recipe = recipeTask.Result;
            if (recipe is null)
            {
                _notFound = true;
                _loading = false;
                return;
            }

            _title = recipe.Title;
            _description = recipe.Description;
            _plan = recipe.Plan;
            _servings = recipe.Servings;
            _sourceUrl = recipe.SourceUrl;
            _selectedTagIds = recipe.Tags.Select(t => t.TagId).ToList();
            _selectedIngredients = recipe.Ingredients.Select(i => new RecipeIngredientModel
            {
                IngredientId = i.IngredientId,
                DisplayName = i.IngredientTitle,
                FreeText = i.FreeText,
                IsManaged = i.IsManaged,
                Amount = i.Amount,
                Unit = i.Unit,
                CustomUnitDescription = i.CustomUnitDescription
            }).ToList();
        }
        else
        {
            await Task.WhenAll(tagsTask, ingredientsTask);

            var (scraped, sourceUrl) = ScrapedState.Consume();
            if (scraped is not null)
            {
                _title = scraped.Title;
                _description = scraped.Description;
                _plan = scraped.Plan;
                _servings = scraped.Servings ?? 2;
                _sourceUrl = sourceUrl;
                _selectedIngredients = scraped.Ingredients.Select(i =>
                {
                    var unitType = i.Unit.Contains("gram", StringComparison.OrdinalIgnoreCase)
                        || i.Unit.Contains("kg", StringComparison.OrdinalIgnoreCase)
                        || i.Unit.Contains("ml", StringComparison.OrdinalIgnoreCase)
                        || i.Unit.Contains("liter", StringComparison.OrdinalIgnoreCase)
                            ? UnitType.Grams
                            : UnitType.Units;

                    return new RecipeIngredientModel
                    {
                        DisplayName = i.Name,
                        FreeText = i.Name,
                        IsManaged = false,
                        Amount = i.Amount,
                        Unit = unitType
                    };
                }).ToList();
            }
        }

        _availableTags = tagsTask.Result.Where(t => t.Type == TagType.Recipe).ToList();
        _allIngredients = ingredientsTask.Result;
        _loading = false;
    }

    private static string RenderMarkdown(string? markdown)
        => string.IsNullOrWhiteSpace(markdown)
            ? "<em style='color:gray;'>Geen inhoud</em>"
            : Markdown.ToHtml(markdown, Pipeline);

    private static string FormatUnitType(UnitType unit) => unit switch
    {
        UnitType.Grams => "Gram",
        UnitType.Units => "Stuks",
        UnitType.Percentage => "Percentage",
        _ => unit.ToString()
    };

    private void ToggleTag(Guid tagId)
    {
        if (_selectedTagIds.Contains(tagId))
            _selectedTagIds.Remove(tagId);
        else
            _selectedTagIds.Add(tagId);
    }

    private bool CanAddIngredient => !string.IsNullOrWhiteSpace(_newRow.DisplayName);

    private List<string> GetSuggestionsFor(RecipeIngredientModel item)
    {
        var text = item.DisplayName;
        if (string.IsNullOrWhiteSpace(text)) return [];
        return _allIngredients
            .Where(i => i.Title.Contains(text, StringComparison.OrdinalIgnoreCase)
                && !i.Title.Equals(text, StringComparison.OrdinalIgnoreCase)
                && !_selectedIngredients.Any(s => s.IngredientId == i.Id))
            .Select(i => i.Title)
            .Take(8)
            .ToList();
    }

    private void OnIngredientTextChanged(RecipeIngredientModel item, string value)
    {
        item.DisplayName = value;
        item.FreeText = value;

        // Resolve managed status
        var match = _allIngredients.FirstOrDefault(i =>
            i.Title.Equals(value, StringComparison.OrdinalIgnoreCase));
        item.IngredientId = match?.Id;
        item.IsManaged = match is not null;
    }

    private void SelectSuggestionFor(RecipeIngredientModel item, string suggestion)
    {
        var match = _allIngredients.FirstOrDefault(i =>
            i.Title.Equals(suggestion, StringComparison.OrdinalIgnoreCase));
        item.DisplayName = match?.Title ?? suggestion;
        item.FreeText = item.DisplayName;
        item.IngredientId = match?.Id;
        item.IsManaged = match is not null;
    }

    private void OnRowKeyDown(RecipeIngredientModel item, KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && item.IsNewRow && CanAddIngredient)
            CommitNewRow();
    }

    private void CommitNewRow()
    {
        var text = _newRow.DisplayName?.Trim();
        if (string.IsNullOrWhiteSpace(text)) return;

        // Prevent duplicates
        var isDuplicate = _newRow.IsManaged
            ? _selectedIngredients.Any(i => i.IngredientId == _newRow.IngredientId)
            : _selectedIngredients.Any(i => !i.IsManaged
                && i.DisplayName.Equals(text, StringComparison.OrdinalIgnoreCase));
        if (isDuplicate) return;

        _newRow.IsNewRow = false;
        _newRow.DisplayName = text;
        _newRow.FreeText = text;
        _selectedIngredients.Add(_newRow);
        _newRow = CreateNewRow();
    }

    private void RemoveIngredient(RecipeIngredientModel item)
        => _selectedIngredients.Remove(item);

    private async Task OpenRecalculateDialog()
    {
        var currentServings = _servings;
        var parameters = new DialogParameters<RecalculateServingsDialog>
        {
            { x => x.CurrentServings, currentServings }
        };

        var dialog = await DialogService.ShowAsync<RecalculateServingsDialog>(
            "Herberekenen", parameters,
            new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true });
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: int newServings } && newServings != currentServings)
        {
            var ratio = (decimal)newServings / currentServings;
            foreach (var ingredient in _selectedIngredients)
            {
                ingredient.Amount = Math.Round(ingredient.Amount * ratio, 2);
            }
            _servings = newServings;
        }
    }

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_title)) return;

        _saving = true;
        _errorMessage = null;

        var request = new CreateRecipeRequest(
            _title.Trim(),
            _description?.Trim() ?? string.Empty,
            _plan ?? string.Empty,
            _servings,
            _sourceUrl?.Trim() ?? string.Empty,
            _selectedTagIds.ToList(),
            _selectedIngredients.Select(i =>
                new RecipeIngredientRequest(i.IngredientId, i.FreeText, i.Amount, i.Unit, i.CustomUnitDescription ?? string.Empty)).ToList());

        if (_isEdit)
        {
            var result = await RecipeService.UpdateAsync(Id!.Value, request);
            if (result.IsSuccess)
            {
                Snackbar.Add("Recept opgeslagen", Severity.Success);
                NavigateBack();
            }
            else
            {
                _errorMessage = result.Error;
            }
        }
        else
        {
            var result = await RecipeService.CreateAsync(request);
            if (result.IsSuccess)
            {
                Snackbar.Add("Recept aangemaakt", Severity.Success);
                NavigateBack();
            }
            else
            {
                _errorMessage = result.Error;
            }
        }

        _saving = false;
    }

    private void NavigateBack() => Navigation.NavigateTo("/recipes");

    public class RecipeIngredientModel
    {
        public Guid? IngredientId { get; set; }
        public string DisplayName { get; set; } = string.Empty;
        public string FreeText { get; set; } = string.Empty;
        public bool IsManaged { get; set; }
        public bool IsNewRow { get; set; }
        public decimal Amount { get; set; } = 1;
        public UnitType Unit { get; set; } = UnitType.Units;
        public string CustomUnitDescription { get; set; } = string.Empty;
    }

    private static RecipeIngredientModel CreateNewRow() => new() { IsNewRow = true };
}

<style>
    .ingredient-grid .mud-input-underline::before,
    .ingredient-grid .mud-input-underline::after {
        border-bottom: none !important;
    }
</style>
