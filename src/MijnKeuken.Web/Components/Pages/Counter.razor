@page "/counter"

<PageTitle>Counter</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Counter</MudText>

<MudText Typo="Typo.body1" Class="mb-3">Huidige telling: <strong>@currentCount</strong></MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="IncrementCount" Size="Size.Medium">
    Klik hier
</MudButton>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}
